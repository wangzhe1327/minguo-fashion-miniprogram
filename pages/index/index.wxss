.nav-bar {
  background: linear-gradient(180deg, #F5F0E8, #F5F0E8);
}

.nav-content {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.logo-icon {
  font-size: 32rpx;
  color: #8B4513;
  letter-spacing: 4rpx;
}

.logo-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-main {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  letter-spacing: 8rpx;
}

.logo-sub {
  font-size: 20rpx;
  color: #A0522D;
  letter-spacing: 4rpx;
  margin-top: 2rpx;
}

.logo-seal {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #C41E3A;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #C41E3A;
  margin-left: 8rpx;
  writing-mode: vertical-rl;
}

/* 搜索栏 */
.search-box {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #FFFFFF;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border: 1rpx solid #E8E0D0;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.search-placeholder {
  color: #BBB;
  font-size: 26rpx;
}

.search-btn {
  width: 100rpx;
  height: 72rpx;
  background: #8B4513;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn text {
  color: #FFF;
  font-size: 26rpx;
}

/* 分类标签 */
.category-tabs {
  height: 80rpx;
  margin: 0 24rpx 20rpx;
}

.tab-list {
  display: flex;
  gap: 20rpx;
  white-space: nowrap;
  padding: 0 4rpx;
}

.tab-item {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #FDF8F0;
  border: 1rpx solid #E8E0D0;
  transition: all 0.3s;
}

.tab-item text {
  font-size: 26rpx;
  color: #666;
}

.tab-item.active {
  background: #8B4513;
  border-color: #8B4513;
}

.tab-item.active text {
  color: #FFF;
}

/* Banner轮播 */
.banner {
  height: 360rpx;
  margin: 0 24rpx 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 30rpx;
  position: relative;
  background: #FDF8F0;
  border-radius: 20rpx;
}

.banner-info {
  flex: 1;
  z-index: 2;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  display: block;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  color: #A0522D;
  display: block;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.banner-btn {
  display: inline-block;
  padding: 14rpx 36rpx;
  background: #8B4513;
  border-radius: 32rpx;
}

.banner-btn text {
  color: #FFF;
  font-size: 24rpx;
}

.banner-img {
  width: 280rpx;
  height: 300rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

/* 分区标题 */
.section-title {
  padding: 20rpx 24rpx 16rpx;
}

.section-title text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 服装网格 */
.clothing-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 24rpx 30rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
