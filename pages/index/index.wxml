<view class="container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="logo-section">
        <text class="logo-icon">—</text>
        <view class="logo-text">
          <text class="logo-main">锦衣旧梦</text>
          <text class="logo-sub">· 民国风服装图鉴 ·</text>
        </view>
        <view class="logo-seal">图鉴</view>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-box">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <input type="text" placeholder="搜索旗袍 / 长衫 / 学生装" placeholder-class="search-placeholder" bindinput="onSearchInput" value="{{searchKeyword}}"/>
    </view>
    <view class="search-btn" bindtap="onSearch">
      <text>搜索</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-tabs" scroll-x="true" show-scrollbar="false">
    <view class="tab-list">
      <view wx:for="{{categories}}" wx:key="id" class="tab-item {{activeCategory === item.id ? 'active' : ''}}" bindtap="onCategoryTap" data-id="{{item.id}}">
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- Banner轮播 -->
  <swiper class="banner" indicator-dots="true" autoplay="true" interval="4000" duration="500" circular="true" indicator-color="rgba(139,69,19,0.3)" indicator-active-color="#8B4513" wx:if="{{activeCategory === 'all' && !searchKeyword}}">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-item" style="background: linear-gradient(135deg, {{item.color}}22, {{item.color}}44);">
        <view class="banner-info">
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-subtitle">{{item.subtitle}}</text>
          <text class="banner-desc">{{item.desc}}</text>
          <view class="banner-btn" bindtap="onBannerTap" data-id="{{item.id}}">
            <text>查看详情</text>
          </view>
        </view>
        <image class="banner-img" src="{{item.image}}" mode="aspectFill"/>
      </view>
    </swiper-item>
  </swiper>

  <!-- 服装列表 -->
  <view class="section-title" wx:if="{{!searchKeyword}}">
    <text>{{activeCategory === 'all' ? '精选推荐' : currentCategoryName}}</text>
  </view>
  <view class="section-title" wx:if="{{searchKeyword}}">
    <text>搜索结果</text>
  </view>

  <view class="clothing-grid">
    <clothing-card wx:for="{{clothingList}}" wx:key="id" item="{{item}}" bind:tap="onClothingTap" data-id="{{item.id}}"/>
  </view>

  <view class="empty-state" wx:if="{{clothingList.length === 0}}">
    <text class="empty-icon">👗</text>
    <text class="empty-text">暂无相关服装</text>
  </view>

  <view class="safe-bottom"></view>
</view>
