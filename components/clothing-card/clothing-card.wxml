<view class="card" bindtap="onTap">
  <view class="card-image-wrap">
    <image class="card-image" src="{{item.image}}" mode="aspectFill" lazy-load="true"/>
    <view class="like-btn" catchtap="onLikeTap">
      <text class="like-icon {{isLiked ? 'liked' : ''}}">♥</text>
    </view>
  </view>
  <view class="card-info">
    <text class="card-name">{{item.name}}</text>
    <text class="card-desc">{{item.subtitle}}</text>
    <view class="card-action">
      <text class="view-btn">查看</text>
    </view>
  </view>
</view>
