.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #F5F0E8;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 32rpx;
  color: #333;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
}

.tryon-area {
  padding: 0 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  margin-top: 24rpx;
}

/* 模特选择 */
.model-scroll {
  height: 160rpx;
}

.model-list {
  display: flex;
  gap: 20rpx;
}

.model-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  background: #FFF;
  border: 2rpx solid transparent;
}

.model-item.active {
  border-color: #8B4513;
}

.model-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-bottom: 8rpx;
}

.model-name {
  font-size: 22rpx;
  color: #666;
}

.model-item.active .model-name {
  color: #8B4513;
}

/* 预览区 */
.preview-section {
  margin-top: 20rpx;
}

.preview-card {
  position: relative;
  background: #FFF;
  border-radius: 20rpx;
  overflow: hidden;
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.model-display {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.3;
}

.model-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.clothing-overlay {
  position: relative;
  z-index: 2;
  width: 60%;
  height: 70%;
}

.overlay-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.preview-info {
  position: absolute;
  bottom: 20rpx;
  left: 24rpx;
  z-index: 3;
}

.preview-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.preview-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

/* 颜色选择 */
.color-list {
  display: flex;
  gap: 16rpx;
}

.color-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  border: 4rpx solid transparent;
}

.color-item.active {
  border-color: #8B4513;
  box-shadow: 0 0 0 4rpx rgba(139,69,19,0.2);
}

/* 尺寸选择 */
.size-list {
  display: flex;
  gap: 16rpx;
}

.size-item {
  width: 80rpx;
  height: 56rpx;
  background: #FFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E8E0D0;
}

.size-item text {
  font-size: 24rpx;
  color: #666;
}

.size-item.active {
  background: #8B4513;
  border-color: #8B4513;
}

.size-item.active text {
  color: #FFF;
}

/* 效果描述 */
.effect-card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.effect-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}
