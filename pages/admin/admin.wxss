.admin-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 34rpx;
}

.admin-nav {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 18rpx;
  background: rgba(248, 243, 234, 0.98);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: content-box;
}

.nav-back,
.nav-spacer {
  width: 62rpx;
  height: 62rpx;
}

.nav-back {
  border-radius: 31rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back text {
  color: var(--ink);
  font-size: 46rpx;
  line-height: 1;
}

.nav-title {
  color: var(--text);
  font-size: 32rpx;
  font-weight: 800;
}

.login-panel,
.admin-toolbar,
.appointment-card,
.empty-state {
  margin: 18rpx 28rpx 0;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
}

.login-panel {
  padding: 28rpx;
}

.panel-title,
.toolbar-title {
  display: block;
  color: var(--text);
  font-size: 32rpx;
  font-weight: 800;
}

.panel-subtitle,
.toolbar-subtitle {
  display: block;
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 23rpx;
}

.input-row {
  margin-top: 24rpx;
}

.input-label {
  display: block;
  margin-bottom: 10rpx;
  color: var(--text);
  font-size: 25rpx;
  font-weight: 700;
}

.admin-input {
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #F8F3EA;
  color: var(--text);
  font-size: 26rpx;
  box-sizing: border-box;
}

.login-action {
  margin-top: 28rpx;
  height: 78rpx;
  border-radius: 39rpx;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-action text {
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 800;
}

.disabled {
  opacity: 0.72;
}

.admin-toolbar {
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.toolbar-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.toolbar-btn {
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 29rpx;
  background: var(--jade);
  display: flex;
  align-items: center;
  justify-content: center;
}

.toolbar-btn.light {
  background: #F8F3EA;
  border: 1rpx solid var(--border);
}

.toolbar-btn text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
}

.toolbar-btn.light text {
  color: var(--primary);
}

.appointment-list {
  padding-bottom: 8rpx;
}

.appointment-card {
  padding: 22rpx;
}

.appointment-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.appointment-no {
  display: block;
  color: var(--primary);
  font-size: 29rpx;
  font-weight: 800;
}

.appointment-time {
  display: block;
  margin-top: 5rpx;
  color: var(--text-light);
  font-size: 22rpx;
}

.status-badge {
  padding: 7rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(47, 109, 98, 0.1);
  color: var(--jade);
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.info-grid {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-row {
  display: flex;
  gap: 18rpx;
}

.info-label {
  width: 72rpx;
  flex-shrink: 0;
  color: var(--text-light);
  font-size: 24rpx;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: var(--text);
  font-size: 24rpx;
  line-height: 1.45;
}

.remark {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 10rpx;
  background: #F8F3EA;
}

.remark text {
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.45;
}

.item-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.item-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.item-rack {
  min-width: 54rpx;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(124, 63, 34, 0.1);
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  flex-shrink: 0;
}

.item-text {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  color: var(--text);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.35;
}

.item-meta {
  margin-top: 4rpx;
  color: var(--text-light);
  font-size: 22rpx;
  line-height: 1.35;
}

.empty-state {
  padding: 80rpx 28rpx;
  display: flex;
  align-items: center;
  flex-direction: column;
}

.empty-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: var(--text-light);
  font-size: 24rpx;
}
