.profile-page {
  background: var(--bg);
  padding-bottom: 32rpx;
}

.page-header {
  height: 90rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  background: rgba(248, 243, 234, 0.98);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: content-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary);
}

.user-card {
  margin: 8rpx 28rpx 18rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, var(--ink), var(--primary));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.user-info {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder text {
  color: #FFFFFF;
  font-size: 38rpx;
  font-weight: 800;
}

.user-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.user-name {
  max-width: 330rpx;
  color: #FFFFFF;
  font-size: 31rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-desc {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
}

.login-btn {
  height: 58rpx;
  padding: 0 28rpx;
  border-radius: 29rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.login-btn text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
}

.stats-bar {
  margin: 0 28rpx 18rpx;
  padding: 26rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  color: var(--primary);
  font-size: 36rpx;
  font-weight: 800;
}

.stat-num.jade {
  color: var(--jade);
}

.stat-label {
  color: var(--text-light);
  font-size: 22rpx;
}

.stat-divider {
  width: 1rpx;
  height: 58rpx;
  background: var(--border);
}

.menu-section {
  margin: 0 28rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  overflow: hidden;
}

.menu-item {
  min-height: 98rpx;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid rgba(231, 220, 206, 0.78);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: rgba(47, 109, 98, 0.1);
  color: var(--jade);
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon.photo {
  background: rgba(180, 61, 50, 0.1);
  color: var(--accent);
}

.menu-icon.retouch {
  background: rgba(124, 63, 34, 0.1);
  color: var(--primary);
}

.menu-icon.admin {
  background: rgba(37, 49, 58, 0.1);
  color: var(--ink);
}

.menu-text-wrap {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.menu-text {
  color: var(--text);
  font-size: 27rpx;
  font-weight: 800;
}

.menu-sub {
  margin-top: 4rpx;
  color: var(--text-light);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  color: #BBB2A8;
  font-size: 36rpx;
  flex-shrink: 0;
}

.favorites-section {
  margin: 0 28rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  color: var(--text);
  font-size: 31rpx;
  font-weight: 800;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
}

.favorites-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.empty-state {
  margin: 0 28rpx;
  padding: 78rpx 28rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: var(--text-light);
  font-size: 24rpx;
  text-align: center;
  line-height: 1.45;
}

.empty-action {
  margin-top: 24rpx;
  height: 62rpx;
  padding: 0 34rpx;
  border-radius: 31rpx;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-action text {
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 800;
}
