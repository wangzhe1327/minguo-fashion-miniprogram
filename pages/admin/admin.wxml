<view class="container admin-page">
  <view class="admin-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack">
      <text>‹</text>
    </view>
    <text class="nav-title">管理员模式</text>
    <view class="nav-spacer"></view>
  </view>

  <view class="login-panel" wx:if="{{!isLoggedIn}}">
    <text class="panel-title">管理员登录</text>
    <text class="panel-subtitle">输入管理员账号和密码后查看用户预约清单</text>

    <view class="input-row">
      <text class="input-label">账号</text>
      <input class="admin-input" placeholder="请输入账号" value="{{username}}" bindinput="onUsernameInput" />
    </view>

    <view class="input-row">
      <text class="input-label">密码</text>
      <input class="admin-input" password="{{true}}" placeholder="请输入管理员密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="login-action {{isLoggingIn ? 'disabled' : ''}}" bindtap="onAdminLogin">
      <text>{{isLoggingIn ? '登录中' : '进入管理员模式'}}</text>
    </view>
  </view>

  <block wx:else>
    <view class="admin-toolbar">
      <view>
        <text class="toolbar-title">预约清单</text>
        <text class="toolbar-subtitle">{{appointments.length}} 条记录</text>
      </view>
      <view class="toolbar-actions">
        <view class="toolbar-btn" bindtap="onRefresh">
          <text>{{isLoading ? '刷新中' : '刷新'}}</text>
        </view>
        <view class="toolbar-btn light" bindtap="onLogout">
          <text>退出</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!isLoading && appointments.length === 0}}">
      <text class="empty-title">还没有预约</text>
      <text class="empty-subtitle">用户提交预约后会显示在这里</text>
    </view>

    <view class="appointment-list">
      <view class="appointment-card" wx:for="{{appointments}}" wx:key="id" wx:for-item="appointment">
        <view class="appointment-head">
          <view>
            <text class="appointment-no">{{appointment.appointmentNo}}</text>
            <text class="appointment-time">{{appointment.createdAtText}}</text>
          </view>
          <text class="status-badge">{{appointment.statusText}}</text>
        </view>

        <view class="info-grid">
          <view class="info-row">
            <text class="info-label">日期</text>
            <text class="info-value">{{appointment.date || '未填写'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">联系</text>
            <text class="info-value">{{appointment.contactName || '未留称呼'}} {{appointment.contactPhone}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">场景</text>
            <text class="info-value">{{appointment.scene || '未填写'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">人数</text>
            <text class="info-value">{{appointment.people || '未填写'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">分区</text>
            <text class="info-value">{{appointment.racksText || '未填写'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">分类</text>
            <text class="info-value">{{appointment.categoriesText || '未填写'}}</text>
          </view>
        </view>

        <view class="remark" wx:if="{{appointment.remark}}">
          <text>{{appointment.remark}}</text>
        </view>

        <view class="item-list">
          <view class="item-row" wx:for="{{appointment.items}}" wx:key="id" wx:for-item="clothing">
            <text class="item-rack">{{clothing.rackLabel}}</text>
            <view class="item-text">
              <text class="item-name">{{clothing.name}}</text>
              <text class="item-meta">{{clothing.categoryName}} · {{clothing.subtitle}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="safe-bottom"></view>
</view>
