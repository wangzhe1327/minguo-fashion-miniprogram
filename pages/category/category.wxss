.category-page {
  background: var(--bg);
}

.page-header {
  height: 96rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  background: rgba(248, 243, 234, 0.98);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: content-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary);
}

.header-action {
  min-width: 98rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.header-action text {
  font-size: 23rpx;
  color: var(--jade);
  font-weight: 700;
}

.category-layout {
  display: flex;
  height: calc(100vh - 96rpx);
}

.left-nav {
  width: 162rpx;
  background: #FFFFFF;
  border-right: 1rpx solid var(--border);
  box-sizing: border-box;
}

.nav-item {
  min-height: 92rpx;
  padding: 20rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(231, 220, 206, 0.7);
  box-sizing: border-box;
}

.nav-item text {
  font-size: 25rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.25;
}

.nav-item.active {
  background: var(--bg);
  border-left: 6rpx solid var(--jade);
}

.nav-item.active text {
  color: var(--primary);
  font-weight: 800;
}

.right-content {
  flex: 1;
  min-width: 0;
  background: var(--bg);
  padding: 18rpx;
  box-sizing: border-box;
}

.category-info {
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
}

.category-banner {
  width: 100%;
  height: 210rpx;
  display: block;
  background: var(--bg-soft);
}

.category-copy {
  padding: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.category-desc {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  color: var(--text-secondary);
  line-height: 1.45;
}

.category-count {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(47, 109, 98, 0.1);
  color: var(--jade);
  font-size: 20rpx;
  font-weight: 700;
}

.clothing-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding-bottom: 36rpx;
}

.empty-state {
  margin-top: 70rpx;
  padding: 72rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 700;
}

.empty-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-light);
}
