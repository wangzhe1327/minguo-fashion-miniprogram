.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(231, 220, 206, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(37, 49, 58, 0.06);
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: var(--bg-soft);
}

.image-skeleton {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F4ECE0, #E7DCCE);
}

.image-skeleton text {
  color: var(--text-light);
  font-size: 22rpx;
}

.card-image {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
}

.like-btn {
  position: absolute;
  z-index: 2;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(37, 49, 58, 0.08);
}

.like-icon {
  font-size: 28rpx;
  color: #B8B0A8;
  line-height: 1;
}

.like-icon.liked {
  color: var(--accent);
}

.selected-badge {
  position: absolute;
  z-index: 2;
  left: 12rpx;
  top: 12rpx;
  padding: 8rpx 14rpx;
  background: rgba(47, 109, 98, 0.92);
  border-radius: 8rpx;
}

.selected-badge text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.card-info {
  padding: 16rpx;
}

.card-name {
  min-height: 68rpx;
  font-size: 27rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.28;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-desc {
  height: 60rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-meta {
  height: 44rpx;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.card-price {
  font-size: 28rpx;
  color: var(--accent);
  font-weight: 700;
  white-space: nowrap;
}

.card-category {
  min-width: 0;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(47, 109, 98, 0.1);
  color: var(--jade);
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-actions {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.card-btn {
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.card-btn text {
  font-size: 23rpx;
  font-weight: 600;
}

.card-btn.ghost {
  border: 1rpx solid var(--border);
  background: #FFFFFF;
}

.card-btn.ghost text {
  color: var(--primary);
}

.card-btn.primary {
  background: var(--primary);
}

.card-btn.primary text {
  color: #FFFFFF;
}

.card-btn.primary.selected {
  background: var(--jade);
}
