.detail-page {
  background: var(--bg);
  padding-bottom: 150rpx;
}

.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 18rpx;
  background: rgba(248, 243, 234, 0.98);
  position: sticky;
  top: 0;
  z-index: 20;
}

.nav-back,
.nav-btn {
  height: 62rpx;
  min-width: 62rpx;
  padding: 0 16rpx;
  border-radius: 31rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.nav-back text {
  color: var(--ink);
  font-size: 46rpx;
  line-height: 1;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text);
}

.nav-actions {
  display: flex;
  gap: 12rpx;
}

.nav-btn text {
  color: var(--text-secondary);
  font-size: 22rpx;
  font-weight: 700;
}

.like-icon {
  font-size: 30rpx;
  color: #B8B0A8;
  line-height: 1;
}

.like-icon.liked {
  color: var(--accent);
}

.detail-swiper {
  height: 620rpx;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #F7EFE4 0%, #E8DDD0 100%);
}

.detail-img {
  width: 100%;
  height: 100%;
}

.detail-info {
  padding: 26rpx 24rpx 0;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.info-titles {
  min-width: 0;
  flex: 1;
}

.detail-name {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text);
  line-height: 1.22;
}

.detail-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.45;
}

.detail-rack {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(124, 63, 34, 0.1);
}

.detail-rack text {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--accent);
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.tag {
  padding: 8rpx 18rpx;
  background: rgba(47, 109, 98, 0.1);
  border-radius: 8rpx;
}

.tag text {
  font-size: 22rpx;
  color: var(--jade);
  font-weight: 700;
}

.detail-section {
  margin-bottom: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  padding: 22rpx;
}

.section-head {
  margin-bottom: 14rpx;
}

.section-label {
  font-size: 29rpx;
  font-weight: 800;
  color: var(--text);
}

.section-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.75;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  padding: 14rpx 16rpx;
  border-radius: 10rpx;
  background: #F8F3EA;
}

.tip-item text {
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.45;
}

.detail-specs {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.spec-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.spec-label {
  width: 124rpx;
  flex-shrink: 0;
  font-size: 25rpx;
  color: var(--text-light);
  line-height: 1.55;
}

.spec-value {
  flex: 1;
  min-width: 0;
  font-size: 25rpx;
  color: var(--text);
  line-height: 1.55;
}

.recommend-scroll {
  height: 248rpx;
}

.recommend-list {
  display: flex;
  gap: 16rpx;
  white-space: nowrap;
}

.recommend-item {
  width: 176rpx;
  display: inline-flex;
  flex-direction: column;
}

.recommend-img {
  width: 176rpx;
  height: 176rpx;
  border-radius: 12rpx;
  background: var(--bg-soft);
}

.recommend-name {
  margin-top: 10rpx;
  width: 100%;
  font-size: 22rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 18rpx 24rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid var(--border);
  display: grid;
  grid-template-columns: 1fr 1fr 1.25fr;
  gap: 14rpx;
  box-sizing: border-box;
}

.footer-btn {
  height: 78rpx;
  border-radius: 39rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.footer-btn text {
  font-size: 26rpx;
  font-weight: 800;
}

.footer-btn.light {
  background: #F8F3EA;
  border: 1rpx solid var(--border);
}

.footer-btn.light text {
  color: var(--primary);
}

.footer-btn.outline {
  background: #FFFFFF;
  border: 1rpx solid var(--jade);
}

.footer-btn.outline text {
  color: var(--jade);
}

.footer-btn.primary {
  background: var(--primary);
}

.footer-btn.primary text {
  color: #FFFFFF;
}

.footer-btn.primary.selected {
  background: var(--jade);
}
