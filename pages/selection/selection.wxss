.selection-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 36rpx;
}

.page-header {
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 18rpx;
  background: rgba(248, 243, 234, 0.98);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-title {
  display: block;
  color: var(--primary);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  display: block;
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
}

.clear-btn {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(180, 61, 50, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn text {
  color: var(--accent);
  font-size: 24rpx;
  font-weight: 700;
}

.summary-panel {
  margin: 10rpx 28rpx 18rpx;
  padding: 24rpx 12rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: stretch;
}

.summary-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.summary-item.wide {
  flex: 1.3;
}

.summary-num {
  max-width: 100%;
  color: var(--jade);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-num.small {
  font-size: 25rpx;
  color: var(--text);
}

.summary-label {
  color: var(--text-light);
  font-size: 22rpx;
}

.summary-divider {
  width: 1rpx;
  background: var(--border);
  margin: 6rpx 4rpx;
}

.form-panel {
  margin: 0 28rpx 24rpx;
  padding: 8rpx 22rpx 22rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
}

.form-row {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(231, 220, 206, 0.75);
  gap: 20rpx;
}

.form-row:last-of-type {
  border-bottom: none;
}

.form-label {
  width: 140rpx;
  flex-shrink: 0;
  color: var(--text);
  font-size: 26rpx;
  font-weight: 700;
}

.form-value {
  min-width: 220rpx;
  height: 60rpx;
  padding: 0 18rpx;
  border-radius: 30rpx;
  background: #F8F3EA;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.form-value text {
  color: var(--text-secondary);
  font-size: 25rpx;
}

.form-input {
  flex: 1;
  height: 60rpx;
  padding: 0 18rpx;
  border-radius: 30rpx;
  background: #F8F3EA;
  color: var(--text);
  font-size: 25rpx;
  text-align: right;
  box-sizing: border-box;
}

.remark-box {
  padding-top: 18rpx;
}

.remark-input {
  width: 100%;
  height: 150rpx;
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #F8F3EA;
  color: var(--text);
  font-size: 25rpx;
  line-height: 1.45;
  box-sizing: border-box;
}

.section-head {
  padding: 0 28rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: var(--text);
  font-size: 31rpx;
  font-weight: 800;
}

.section-count {
  color: var(--text-light);
  font-size: 23rpx;
}

.selected-list {
  margin: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.selected-item {
  min-height: 190rpx;
  padding: 14rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
}

.selected-img {
  width: 154rpx;
  height: 154rpx;
  border-radius: 12rpx;
  background: var(--bg-soft);
  flex-shrink: 0;
}

.selected-info {
  flex: 1;
  min-width: 0;
  align-self: stretch;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.selected-name {
  color: var(--text);
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.selected-desc {
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.selected-meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.selected-price {
  color: var(--accent);
  font-size: 26rpx;
  font-weight: 800;
}

.selected-category {
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(47, 109, 98, 0.1);
  color: var(--jade);
  font-size: 20rpx;
}

.remove-btn {
  width: 72rpx;
  height: 58rpx;
  border-radius: 29rpx;
  border: 1rpx solid rgba(180, 61, 50, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.remove-btn text {
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 700;
}

.empty-state {
  margin: 0 28rpx 24rpx;
  padding: 78rpx 28rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: var(--text-light);
  font-size: 24rpx;
  text-align: center;
  line-height: 1.45;
}

.empty-action {
  margin-top: 24rpx;
  height: 62rpx;
  padding: 0 34rpx;
  border-radius: 31rpx;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-action text {
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 800;
}

.actions {
  margin: 24rpx 28rpx 0;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 16rpx;
}

.action-btn {
  height: 82rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.action-btn text {
  font-size: 27rpx;
  font-weight: 800;
}

.action-btn.secondary {
  background: #FFFFFF;
  border: 1rpx solid var(--border);
}

.action-btn.secondary text {
  color: var(--primary);
}

.action-btn.primary {
  background: var(--jade);
}

.action-btn.primary text {
  color: #FFFFFF;
}
