.home-page {
  background: var(--bg);
  padding-bottom: 28rpx;
}

.nav-bar {
  background: rgba(248, 243, 234, 0.98);
}

.nav-content {
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.brand {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-mark {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid var(--accent);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.brand-mark text {
  color: var(--accent);
  font-size: 28rpx;
  font-weight: 700;
}

.brand-text {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
  color: var(--primary);
}

.brand-subtitle {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--text-light);
}

.selection-entry {
  width: 112rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-shadow: 0 6rpx 18rpx rgba(37, 49, 58, 0.06);
}

.selection-num {
  color: var(--jade);
  font-size: 28rpx;
  font-weight: 800;
}

.selection-label {
  color: var(--text-secondary);
  font-size: 22rpx;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx 18rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  background: #FFFFFF;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.search-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(47, 109, 98, 0.1);
  color: var(--jade);
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.search-input input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--text);
}

.search-placeholder {
  color: #B9B0A6;
  font-size: 26rpx;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn text {
  color: var(--text-light);
  font-size: 34rpx;
  line-height: 1;
}

.search-btn {
  width: 104rpx;
  height: 76rpx;
  background: var(--primary);
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
}

.category-tabs {
  height: 78rpx;
  margin: 0 0 18rpx;
}

.tab-list {
  display: flex;
  gap: 16rpx;
  white-space: nowrap;
  padding: 0 28rpx;
}

.tab-item {
  height: 60rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.tab-item text {
  font-size: 25rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.tab-item.active {
  background: var(--primary);
  border-color: var(--primary);
}

.tab-item.active text {
  color: #FFFFFF;
}

.service-strip {
  margin: 0 28rpx 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(37, 49, 58, 0.04);
}

.service-mark {
  width: 58rpx;
  height: 58rpx;
  border-radius: 14rpx;
  background: rgba(47, 109, 98, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.service-mark text {
  color: var(--jade);
  font-size: 24rpx;
  font-weight: 800;
}

.service-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.service-title {
  color: var(--text);
  font-size: 27rpx;
  font-weight: 800;
}

.service-desc {
  margin-top: 4rpx;
  color: var(--text-light);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-arrow {
  color: #BBB2A8;
  font-size: 36rpx;
  flex-shrink: 0;
}

.banner {
  height: 330rpx;
  margin: 0 28rpx 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #FFFFFF 0%, #EFE7D9 100%);
  border: 1rpx solid rgba(231, 220, 206, 0.9);
}

.banner-copy {
  min-width: 0;
  flex: 1;
}

.banner-kicker {
  display: block;
  font-size: 22rpx;
  color: var(--jade);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.banner-title {
  display: block;
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.18;
  max-height: 86rpx;
  overflow: hidden;
}

.banner-desc {
  display: -webkit-box;
  margin-top: 12rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.banner-action {
  margin-top: 18rpx;
  width: 144rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: var(--jade);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-action text {
  color: #FFFFFF;
  font-size: 23rpx;
  font-weight: 700;
}

.banner-image-wrap {
  width: 218rpx;
  height: 270rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: var(--bg-soft);
  flex-shrink: 0;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.section-head {
  padding: 0 28rpx 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text);
  line-height: 1.2;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.section-action {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(47, 109, 98, 0.1);
}

.section-action text {
  color: var(--jade);
  font-size: 23rpx;
  font-weight: 700;
}

.clothing-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  padding: 0 28rpx 32rpx;
  box-sizing: border-box;
}

.empty-state {
  margin: 80rpx 28rpx 0;
  padding: 80rpx 28rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 700;
}

.empty-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-light);
}
