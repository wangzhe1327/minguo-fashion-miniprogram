<view class="container profile-page">
  <view class="page-header" style="padding-top: {{statusBarHeight}}px;">
    <text class="page-title">我的</text>
  </view>

  <view class="user-card">
    <view class="user-info">
      <view class="avatar-wrap">
        <image wx:if="{{userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <view class="avatar-placeholder" wx:else>
          <text>锦</text>
        </view>
      </view>
      <view class="user-text">
        <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
        <text class="user-desc" wx:if="{{userInfo.nickName}}">你的民国风选款空间</text>
        <text class="user-desc" wx:else>登录后同步昵称和头像</text>
      </view>
    </view>
    <view class="login-btn" wx:if="{{!userInfo.nickName}}" bindtap="onLogin">
      <text>登录</text>
    </view>
  </view>

  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">{{favorites.length}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToSelection">
      <text class="stat-num jade">{{selectionCount}}</text>
      <text class="stat-label">清单</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{browseCount}}</text>
      <text class="stat-label">浏览</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToGallery">
      <view class="menu-left">
        <text class="menu-icon photo">片</text>
        <view class="menu-text-wrap">
          <text class="menu-text">摄影取片</text>
          <text class="menu-sub">输入取片码预览并保存照片</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToRetouch">
      <view class="menu-left">
        <text class="menu-icon retouch">修</text>
        <view class="menu-text-wrap">
          <text class="menu-text">精修特效</text>
          <text class="menu-sub">提交修图需求并查看交付进度</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSelection">
      <view class="menu-left">
        <text class="menu-icon">清</text>
        <view class="menu-text-wrap">
          <text class="menu-text">选款清单</text>
          <text class="menu-sub">整理并复制咨询单</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-left">
        <text class="menu-icon">藏</text>
        <view class="menu-text-wrap">
          <text class="menu-text">继续逛款</text>
          <text class="menu-sub">回到首页浏览更多服装</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToHistory">
      <view class="menu-left">
        <text class="menu-icon">览</text>
        <view class="menu-text-wrap">
          <text class="menu-text">浏览记录</text>
          <text class="menu-sub">查看最近看过的款式</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-left">
        <text class="menu-icon">锦</text>
        <view class="menu-text-wrap">
          <text class="menu-text">关于锦衣旧梦</text>
          <text class="menu-sub">{{totalCount}} 款民国风服装图鉴</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="favorites-section" wx:if="{{favorites.length > 0}}">
    <view class="section-header">
      <view>
        <text class="section-title">我的收藏</text>
        <text class="section-subtitle">收藏是偏好，清单是准备咨询的款式</text>
      </view>
    </view>
    <view class="favorites-grid">
      <clothing-card
        wx:for="{{favoriteItems}}"
        wx:key="id"
        item="{{item}}"
        bind:tap="onClothingTap"
        bind:selectchange="onSelectionChange"
        bind:likechange="onLikeChange"
      />
    </view>
  </view>

  <view class="empty-state" wx:if="{{favorites.length === 0}}">
    <text class="empty-title">还没有收藏</text>
    <text class="empty-subtitle">先去首页看看，喜欢的款式可以收藏或加入清单</text>
    <view class="empty-action" bindtap="goToFavorites">
      <text>去浏览</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
