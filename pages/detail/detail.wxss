.container {
  background: #F5F0E8;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 顶部导航 */
.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #F5F0E8;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 32rpx;
  color: #333;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-actions {
  display: flex;
  gap: 16rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.like-icon {
  font-size: 32rpx;
  color: #CCC;
}

.like-icon.liked {
  color: #C41E3A;
}

.share-icon {
  font-size: 28rpx;
  color: #666;
}

/* 轮播图 */
.detail-swiper {
  height: 600rpx;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.detail-img {
  width: 100%;
  height: 100%;
}

/* 信息区 */
.detail-info {
  padding: 30rpx 24rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.info-titles {
  flex: 1;
}

.detail-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.detail-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.detail-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #C41E3A;
}

.detail-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: #FDF8F0;
  border: 1rpx solid #E8E0D0;
  border-radius: 8rpx;
}

.tag text {
  font-size: 22rpx;
  color: #8B4513;
}

/* 分区 */
.detail-section {
  margin-bottom: 30rpx;
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.section-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

/* 规格 */
.detail-specs {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.spec-row {
  display: flex;
  gap: 20rpx;
}

.spec-label {
  font-size: 26rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.spec-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

/* 推荐 */
.recommend-scroll {
  height: 240rpx;
}

.recommend-list {
  display: flex;
  gap: 16rpx;
  white-space: nowrap;
}

.recommend-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
}

.recommend-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.recommend-name {
  font-size: 22rpx;
  color: #666;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  text-align: center;
}

/* 底部按钮 */
.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFF;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E8E0D0;
  display: flex;
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F0E8;
  border: 1rpx solid #E8E0D0;
}

.footer-btn.primary {
  background: #8B4513;
  border-color: #8B4513;
}

.footer-btn text {
  font-size: 28rpx;
  color: #8B4513;
}

.footer-btn.primary text {
  color: #FFF;
}
