<view class="container">
  <view class="page-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-icon">←</text>
    </view>
    <text class="page-title">虚拟试穿</text>
    <view style="width: 64rpx;"></view>
  </view>

  <view class="tryon-area">
    <!-- 模特选择 -->
    <view class="model-section">
      <text class="section-title">选择模特</text>
      <scroll-view class="model-scroll" scroll-x="true" show-scrollbar="false">
        <view class="model-list">
          <view class="model-item {{selectedModel === index ? 'active' : ''}}"
                wx:for="{{models}}" wx:key="index"
                bindtap="onModelSelect" data-index="{{index}}">
            <image class="model-avatar" src="{{item.avatar}}" mode="aspectFill"/>
            <text class="model-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 试穿预览 -->
    <view class="preview-section">
      <view class="preview-card">
        <view class="model-display">
          <image class="model-img" src="{{models[selectedModel].image}}" mode="aspectFit"/>
        </view>
        <view class="clothing-overlay">
          <image class="overlay-img" src="{{item.image}}" mode="aspectFit"/>
        </view>
        <view class="preview-info">
          <text class="preview-name">{{item.name}}</text>
          <text class="preview-subtitle">{{item.subtitle}}</text>
        </view>
      </view>
    </view>

    <!-- 颜色选择 -->
    <view class="color-section">
      <text class="section-title">颜色选择</text>
      <view class="color-list">
        <view class="color-item {{selectedColor === index ? 'active' : ''}}"
              wx:for="{{colors}}" wx:key="index"
              bindtap="onColorSelect" data-index="{{index}}"
              style="background: {{item}};">
        </view>
      </view>
    </view>

    <!-- 尺寸选择 -->
    <view class="size-section">
      <text class="section-title">尺码选择</text>
      <view class="size-list">
        <view class="size-item {{selectedSize === index ? 'active' : ''}}"
              wx:for="{{sizes}}" wx:key="index"
              bindtap="onSizeSelect" data-index="{{index}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 效果描述 -->
    <view class="effect-section">
      <text class="section-title">试穿效果</text>
      <view class="effect-card">
        <text class="effect-text">{{effectDesc}}</text>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
