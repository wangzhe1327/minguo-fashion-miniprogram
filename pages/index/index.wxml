<view class="container home-page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="brand">
        <view class="brand-mark">
          <image class="brand-mark-img" src="/images/brand_emblem_fuguang.jpg" mode="aspectFill" />
        </view>
        <view class="brand-text">
          <text class="brand-title">浮光旅影</text>
          <view class="brand-subtitle-row">
            <view class="brand-subtitle-line"></view>
            <text class="brand-subtitle">民国影像 · 服装图鉴</text>
          </view>
        </view>
      </view>
      <view class="selection-entry" bindtap="goSelection">
        <text class="selection-num">{{selectionCount}}</text>
        <text class="selection-label">清单</text>
      </view>
    </view>
  </view>

  <view class="search-box">
    <view class="search-input">
      <text class="search-icon">搜</text>
      <input
        type="text"
        placeholder="搜索旗袍 / 长衫 / 学生装"
        placeholder-class="search-placeholder"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        value="{{searchKeyword}}"
      />
      <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="onClearSearch">
        <text>×</text>
      </view>
    </view>
    <view class="search-btn" bindtap="onSearch">
      <text>搜索</text>
    </view>
  </view>

  <scroll-view class="category-tabs" scroll-x="true" show-scrollbar="false">
    <view class="tab-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="tab-item {{activeCategory === item.id ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="service-strip" bindtap="goGallery">
    <view class="service-mark">
      <text>片</text>
    </view>
    <view class="service-copy">
      <text class="service-title">摄影取片 · 精修特效</text>
      <text class="service-desc">预览成片、保存原片、提交商业精修</text>
    </view>
    <text class="service-arrow">›</text>
  </view>

  <swiper
    class="banner"
    indicator-dots="true"
    autoplay="true"
    interval="4200"
    duration="500"
    circular="true"
    indicator-color="rgba(124,63,34,0.22)"
    indicator-active-color="#2F6D62"
    wx:if="{{activeCategory === 'all' && !searchKeyword && banners.length > 0}}"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-item" bindtap="onBannerTap" data-id="{{item.id}}">
        <view class="banner-copy">
          <text class="banner-kicker">{{item.subtitle}}</text>
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-desc">{{item.desc}}</text>
          <view class="banner-action">
            <text>查看详情</text>
          </view>
        </view>
        <view class="banner-image-wrap">
          <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="section-head" wx:if="{{!isLoadingAssets}}">
    <view>
      <text class="section-title">{{searchKeyword ? '搜索结果' : (activeCategory === 'all' ? '精选推荐' : currentCategoryName)}}</text>
      <text class="section-subtitle">{{clothingList.length}} 款可选</text>
    </view>
    <view class="section-action" bindtap="goSelection" wx:if="{{selectionCount > 0}}">
      <text>查看清单</text>
    </view>
  </view>

  <view class="clothing-grid" wx:if="{{!isLoadingAssets}}">
    <clothing-card
      wx:for="{{clothingList}}"
      wx:key="id"
      item="{{item}}"
      bind:tap="onClothingTap"
      bind:selectchange="onSelectionChange"
      bind:likechange="onLikeChange"
    />
  </view>

  <view class="empty-state" wx:if="{{!isLoadingAssets && clothingList.length === 0}}">
    <text class="empty-title">暂无相关服装</text>
    <text class="empty-subtitle">换一个关键词或分类再看看</text>
  </view>

  <view class="safe-bottom"></view>
</view>
