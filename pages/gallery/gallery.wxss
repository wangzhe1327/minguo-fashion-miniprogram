.gallery-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 150rpx;
}

.page-header {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 18rpx;
  background: rgba(248, 243, 234, 0.98);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn,
.header-space {
  width: 64rpx;
  height: 64rpx;
}

.back-btn {
  border-radius: 32rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn text {
  color: var(--ink);
  font-size: 46rpx;
  line-height: 1;
}

.title-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-title {
  color: var(--primary);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
}

.code-panel,
.album-panel {
  margin: 10rpx 28rpx 18rpx;
  padding: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
}

.panel-label {
  display: block;
  color: var(--text);
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.code-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 38rpx;
  background: #F8F3EA;
  color: var(--text);
  font-size: 27rpx;
  box-sizing: border-box;
}

.search-btn {
  width: 116rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-btn.disabled {
  opacity: 0.55;
}

.search-btn text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
}

.album-panel {
  margin-top: 0;
}

.album-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.album-title-wrap {
  min-width: 0;
  flex: 1;
}

.album-title {
  display: block;
  color: var(--text);
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.3;
}

.album-meta {
  display: block;
  margin-top: 8rpx;
  color: var(--text-light);
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.photo-count {
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: rgba(47, 109, 98, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.photo-count text {
  color: var(--jade);
  font-size: 23rpx;
  font-weight: 800;
}

.album-notice {
  display: block;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 10rpx;
  background: #F8F3EA;
  color: var(--text-secondary);
  font-size: 23rpx;
  line-height: 1.45;
}

.toolbar {
  margin: 0 28rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toolbar-btn {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.toolbar-btn text {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 800;
}

.toolbar-count {
  color: var(--text-light);
  font-size: 23rpx;
}

.photo-grid {
  padding: 0 28rpx 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  box-sizing: border-box;
}

.photo-card {
  overflow: hidden;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
}

.photo-wrap {
  position: relative;
  width: 100%;
  height: 260rpx;
  background: var(--bg-soft);
}

.photo-img {
  width: 100%;
  height: 100%;
}

.select-dot {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.select-dot.selected {
  background: var(--jade);
  border-color: var(--jade);
}

.select-dot text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
}

.retouch-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 7rpx 13rpx;
  border-radius: 8rpx;
  background: rgba(124, 63, 34, 0.92);
}

.retouch-badge text {
  color: #FFFFFF;
  font-size: 20rpx;
}

.photo-info {
  padding: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.photo-name {
  min-width: 0;
  color: var(--text);
  font-size: 24rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.save-one {
  width: 72rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: rgba(47, 109, 98, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.save-one text {
  color: var(--jade);
  font-size: 22rpx;
  font-weight: 800;
}

.empty-state {
  margin: 0 28rpx;
  padding: 82rpx 28rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: var(--text-light);
  font-size: 24rpx;
  text-align: center;
  line-height: 1.45;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.progress-text {
  flex: 1;
  min-width: 0;
}

.progress-text text {
  color: var(--text-light);
  font-size: 23rpx;
  line-height: 1.3;
}

.save-selected {
  width: 178rpx;
  height: 78rpx;
  border-radius: 39rpx;
  background: var(--jade);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.retouch-selected {
  width: 178rpx;
  height: 78rpx;
  border-radius: 39rpx;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.save-selected.disabled {
  opacity: 0.55;
}

.save-selected text,
.retouch-selected text {
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 800;
}
