.retouch-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 36rpx;
}

.page-header {
  padding-left: 28rpx;
  padding-right: 28rpx;
  padding-bottom: 18rpx;
  background: rgba(248, 243, 234, 0.98);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-btn text {
  color: var(--primary);
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1;
  transform: translateY(-2rpx);
}

.title-wrap {
  min-width: 0;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.page-title {
  color: var(--primary);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.15;
}

.page-subtitle {
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
}

.history-btn,
.change-btn {
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.history-btn text,
.change-btn text {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 800;
}

.intro-panel,
.draft-panel,
.empty-draft,
.section-block,
.form-panel,
.orders-section {
  margin: 12rpx 28rpx 20rpx;
  padding: 22rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
}

.intro-title {
  display: block;
  color: var(--text);
  font-size: 29rpx;
  font-weight: 800;
}

.intro-desc {
  display: block;
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.55;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 800;
}

.section-subtitle {
  display: block;
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
}

.photo-scroll {
  height: 172rpx;
}

.photo-list {
  display: flex;
  gap: 14rpx;
  white-space: nowrap;
}

.draft-photo {
  width: 154rpx;
  height: 154rpx;
  border-radius: 12rpx;
  background: var(--bg-soft);
}

.empty-draft {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 28rpx;
}

.empty-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-subtitle {
  margin-top: 10rpx;
  color: var(--text-light);
  font-size: 24rpx;
  text-align: center;
  line-height: 1.45;
}

.empty-action {
  margin-top: 24rpx;
  height: 64rpx;
  padding: 0 34rpx;
  border-radius: 32rpx;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-action text {
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 800;
}

.package-list,
.effect-list,
.delivery-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.package-card,
.effect-card,
.delivery-card {
  padding: 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--border);
  background: #F8F3EA;
}

.package-card.active,
.effect-card.active,
.delivery-card.active {
  background: rgba(47, 109, 98, 0.08);
  border-color: var(--jade);
}

.package-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.package-name,
.effect-name,
.delivery-name {
  color: var(--text);
  font-size: 27rpx;
  font-weight: 800;
}

.package-tag {
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(180, 61, 50, 0.1);
  color: var(--accent);
  font-size: 20rpx;
  font-weight: 700;
}

.package-price {
  display: block;
  margin-top: 10rpx;
  color: var(--accent);
  font-size: 30rpx;
  font-weight: 800;
}

.package-desc,
.effect-desc,
.delivery-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 23rpx;
  line-height: 1.45;
}

.effect-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.effect-color {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
}

.effect-copy {
  min-width: 0;
  flex: 1;
}

.form-row {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid rgba(231, 220, 206, 0.75);
}

.form-label {
  width: 136rpx;
  color: var(--text);
  font-size: 26rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  padding: 0 18rpx;
  border-radius: 30rpx;
  background: #F8F3EA;
  color: var(--text);
  font-size: 25rpx;
  box-sizing: border-box;
}

.remark-box {
  padding-top: 18rpx;
}

.remark-input {
  width: 100%;
  height: 166rpx;
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #F8F3EA;
  color: var(--text);
  font-size: 25rpx;
  line-height: 1.45;
  box-sizing: border-box;
}

.terms-row {
  margin: 0 28rpx 20rpx;
  padding: 20rpx 22rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: var(--jade);
  border-color: var(--jade);
}

.checkbox text {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
}

.terms-text {
  color: var(--text-secondary);
  font-size: 23rpx;
  line-height: 1.45;
}

.submit-panel {
  margin: 0 28rpx 24rpx;
  padding: 20rpx 22rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.amount-box {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.amount-label {
  color: var(--text-light);
  font-size: 22rpx;
}

.amount-value {
  margin-top: 4rpx;
  color: var(--accent);
  font-size: 38rpx;
  font-weight: 800;
}

.submit-btn {
  height: 78rpx;
  padding: 0 34rpx;
  border-radius: 39rpx;
  background: var(--jade);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.submit-btn.disabled {
  opacity: 0.55;
}

.submit-btn text {
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 800;
}

.orders-section {
  padding-bottom: 8rpx;
}

.order-card {
  padding: 18rpx;
  margin-bottom: 14rpx;
  background: #F8F3EA;
  border-radius: 14rpx;
  border: 1rpx solid var(--border);
}

.order-head,
.order-line {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.order-no {
  display: block;
  color: var(--text);
  font-size: 26rpx;
  font-weight: 800;
}

.order-meta {
  display: block;
  margin-top: 6rpx;
  color: var(--text-light);
  font-size: 22rpx;
}

.status-badge {
  padding: 7rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.status-badge text {
  color: #FFFFFF;
  font-size: 21rpx;
  font-weight: 800;
}

.order-line {
  margin-top: 14rpx;
}

.order-line text {
  color: var(--text-secondary);
  font-size: 23rpx;
}

.result-scroll {
  height: 180rpx;
  margin-top: 16rpx;
}

.result-list {
  display: flex;
  gap: 14rpx;
  white-space: nowrap;
}

.result-item {
  position: relative;
  width: 152rpx;
  height: 152rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: var(--bg-soft);
}

.result-img {
  width: 152rpx;
  height: 152rpx;
}

.result-save {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(47, 109, 98, 0.94);
}

.result-save text {
  color: #FFFFFF;
  font-size: 20rpx;
}

.order-tip {
  display: block;
  margin-top: 14rpx;
  color: var(--text-light);
  font-size: 23rpx;
  line-height: 1.45;
}
